    "socket.io-client": "^4.5.4",
    "react-hook-form": "^7.48.2",
    "zod": "^3.22.4",
    "@hookform/resolvers": "^3.3.2",
    "framer-motion": "^10.16.16",
    "recharts": "^2.10.3",
    "@monaco-editor/react": "^4.6.0",
    "react-query": "^3.39.3",
    "react-hot-toast": "^2.4.1",
    "date-fns": "^2.30.0",
    "react-intersection-observer": "^9.5.3",
    "react-window": "^1.8.10",
