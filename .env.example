# .env.example

# API Configuration
VITE_API_URL=https://api.changexacademy.ng
VITE_WS_URL=wss://api.changexacademy.ng

# Authentication
VITE_GOOGLE_CLIENT_ID=your_google_client_id
VITE_GITHUB_CLIENT_ID=your_github_client_id
VITE_LINKEDIN_CLIENT_ID=your_linkedin_client_id

# Social Auth Redirect URLs
VITE_GOOGLE_AUTH_URL=https://api.changexacademy.ng/auth/google
VITE_GITHUB_AUTH_URL=https://api.changexacademy.ng/auth/github
VITE_LINKEDIN_AUTH_URL=https://api.changexacademy.ng/auth/linkedin

# Payment Gateways
VITE_PAYSTACK_PUBLIC_KEY=pk_live_xxxxx
VITE_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-xxxxx

# Analytics & Monitoring
VITE_SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
VITE_POSTHOG_KEY=phc_xxxxx
VITE_POSTHOG_HOST=https://app.posthog.com

# Features
VITE_ENABLE_2FA=true
VITE_ENABLE_SOCIAL_LOGIN=true
VITE_ENABLE_OFFLINE_MODE=true

# Cloudinary (for image uploads)
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=changex_uploads

# App Configuration
VITE_APP_NAME=Change X Academy
VITE_APP_URL=https://changexacademy.ng
VITE_APP_ENV=production
